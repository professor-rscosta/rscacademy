# ============================================================
# RSC Academy — Variáveis de Ambiente
# Copie este arquivo para .env e preencha com suas credenciais
# NUNCA commite o arquivo .env no Git
# ============================================================

# ── Servidor ─────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── JWT ──────────────────────────────────────────────────────
# Gere uma chave segura: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=SUBSTITUA_POR_CHAVE_SEGURA_DE_64_CHARS

# ── MySQL (Hostinger) ─────────────────────────────────────────
# Preencha com os dados do banco criado no hPanel > Databases
DB_HOST=localhost
DB_PORT=3306
DB_USER=usuario_do_banco
DB_PASS=senha_do_banco
DB_NAME=nome_do_banco

# ── IA (pelo menos um obrigatório) ───────────────────────────
AI_PROVIDER=openai
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# Gemini como fallback (opcional)
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash
