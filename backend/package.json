{
  "name": "rsc-academy-backend",
  "version": "1.0.0",
  "description": "RSC Academy Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "seed": "node src/database/seed.js",
    "build": "node -e \"const fs=require('fs'); fs.existsSync('public/index.html') ? console.log('Build ok: frontend ready') : console.error('WARNING: public/index.html not found')\"",
    "migrate": "node src/database/migrate-json-to-mysql.js",
    "seed:mysql": "node src/database/seed-mysql.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "iconv-lite": "^0.7.2",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.8.0",
    "morgan": "^1.10.0",
    "mysql2": "^3.22.2",
    "pdf-parse": "^2.4.5",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}